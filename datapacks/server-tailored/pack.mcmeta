{
	"pack": {
		"description": "Recipes tailored for The Server",
		"pack_format": 15
	},
	"filter": {
		"block": [
			{
				"namespace": "tconstruct",
				"path": "recipes/smeltery/melting/metal/(aluminum|uranium|tungsten|platinum)/(ore|dust|raw|raw_block)"
			},
			{
				"namespace": "create",
				"path": "splashing/([^/]+)/crushed_raw_(aluminum|uranium|tungsten|platinum)"
			},
			{
				"namespace": "create",
				"path": "(smelting|blasting)/(aluminum|uranium|tungsten|platinum)_ingot_compat_([^/]+)"
			},
			{
				"namespace": "create",
				"path": "(smelting|blasting)/ingot_(aluminum|uranium|tungsten|platinum)_compat_([^/]+)"
			},
			{
				"namespace": "create",
				"path": "crushing/(aluminum|uranium|tungsten|platinum)_ore"
			},
			{
				"namespace": "create",
				"path": "crushing/raw_(aluminum|uranium|tungsten|platinum)"
			},
			{
				"namespace": "create",
				"path": "crushing/raw_(aluminum|uranium|tungsten|platinum)_block"
			}
		]
	}
}